{
  "name": "aura-wellness",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": ["apps/*", "packages/*", "packages/engines/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "npm run test --workspaces --if-present",
    "dev:web": "npm run dev --workspace=@aura/web",
    "dev:mobile": "npm run start --workspace=@aura/mobile",
    "build:web": "npm run build --workspace=@aura/web"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "5.8.2"
  }
}
