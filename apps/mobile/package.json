{
  "name": "@aura/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "npm run typecheck",
    "preflight:android:eas:quick": "cd android && EXPO_NO_METRO_WORKSPACE_ROOT=1 EAS_BUILD=true ./gradlew :app:buildReleasePreBundle --no-daemon --console=plain",
    "preflight:android:eas:full": "cd android && EXPO_NO_METRO_WORKSPACE_ROOT=1 EAS_BUILD=true ./gradlew clean :app:bundleRelease --no-daemon --console=plain"
  },
  "dependencies": {
    "@aura/fitness-engine": "*",
    "@aura/lib": "*",
    "@aura/lifestyle-engine": "*",
    "@aura/mental-engine": "*",
    "@aura/spiritual-engine": "*",
    "@aura/types": "*",
    "@react-native-async-storage/async-storage": "2.1.2",
    "@sentry/react-native": "~6.14.0",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-react-native": "^1.0.0",
    "expo": "~53.0.0",
    "expo-audio": "~0.4.9",
    "expo-blur": "~14.1.5",
    "expo-camera": "~16.1.11",
    "expo-constants": "~17.1.8",
    "expo-font": "~13.3.2",
    "expo-gl": "~15.1.7",
    "expo-linear-gradient": "~14.1.5",
    "expo-linking": "~7.1.7",
    "expo-notifications": "~0.31.5",
    "expo-router": "~5.1.11",
    "expo-secure-store": "~14.2.4",
    "expo-speech": "~13.1.7",
    "expo-status-bar": "~2.2.3",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^4.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.6",
    "react-native-fs": "^2.20.0",
    "react-native-reanimated": "~3.17.4",
    "react-native-safe-area-context": "5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "~15.11.2",
    "react-native-web": "^0.20.0",
    "react-native-worklets": "^0.7.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~19.0.10",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3"
  },
  "expo": {
    "doctor": {
      "appConfigFieldsNotSyncedCheck": {
        "enabled": false
      },
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-fs"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
