# ── API Target ────────────────────────────────────────────────────────────────
# Local dev (same machine):  http://localhost:3000/api
# Local dev (physical device): http://192.168.x.x:3000/api  (use your LAN IP)
# Production:                 https://your-domain.com/api
#
# REQUIRED for production builds — the app will throw at startup without it.
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# ── Sentry (optional in dev, recommended in production) ──────────────────────
# Public runtime DSN read by the app at startup.
EXPO_PUBLIC_SENTRY_DSN=https://use-your-own-sentry-dsn

# Sentry source-map upload settings for EAS builds.
# Use your own org slug/project slug and set auth token via EAS secrets.
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

