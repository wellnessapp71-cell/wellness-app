# ── Database ──────────────────────────────────────────────────────────────────
# DATABASE_URL is set in packages/db/.env (not committed to git)

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED: Generate a strong secret for production: openssl rand -base64 48
#JWT_SECRET=random-dev-jwt-secret-change-me-1234567890abcd
JWT_EXPIRY=7d

# Compatibility mode for legacy clients without tokens.
# Defaults to disabled. Only set AUTH_COMPAT=true in local dev if you need
# the legacy userId fallback. Production MUST leave this unset (or "false").
#   true        -> allow legacy userId fallback (dev only)
#   unset/false -> require valid Bearer token for all protected endpoints
# AUTH_COMPAT=true

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of browser origins allowed to make API requests.
# Native mobile clients (no Origin header) bypass CORS and are unaffected.
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# ── Sentry (optional in dev, recommended in production) ──────────────────────
#SENTRY_DSN=https://46480b3100e6b409382bec309f69e35b@o4511169257144320.ingest.us.sentry.io/4511169259307008
